{
  "expo": {
    "name": "Tazq",
    "slug": "Tazq-Frontend",
    "owner": "melihctn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/tazq_icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "tazq-app",
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4",
            "newArchEnabled": false
          },
          "android": {
            "usesCleartextTraffic": true,
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "buildToolsVersion": "34.0.0"
          }
        }
      ],
      "expo-font",
      "expo-localization",
      "expo-audio",
      "@react-native-community/datetimepicker",
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "Tazq needs access to the microphone to record your tasks.",
          "speechRecognitionPermission": "Tazq needs access to speech recognition to convert your voice to text."
        }
      ]
    ],
    "splash": {
      "image": "./assets/images/tazq_splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tazqapp.tazq",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Tazq needs access to the microphone to record your tasks.",
        "NSSpeechRecognitionUsageDescription": "Tazq needs access to speech recognition to convert your voice to text.",
        "NSPhotoLibraryUsageDescription": "Tazq needs access to your photo library if you want to attach images to your tasks.",
        "NSCameraUsageDescription": "Tazq needs access to your camera if you want to take photos for your tasks.",
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/tazq_icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.tazqapp.tazq",
      "backgroundColor": "#000000",
      "softwareKeyboardLayoutMode": "resize",
      "navigationBar": {
        "backgroundColor": "#000000",
        "barStyle": "light-content"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "de37967e-e414-4881-ba6f-6e17f04c974e"
      }
    }
  }
}
