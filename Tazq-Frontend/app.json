{
  "expo": {
    "name": "TAZQ",
    "slug": "Tazq-Frontend",
    "owner": "melihctn",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/brand/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "tazq-app",
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4",
            "newArchEnabled": true,
            "useFrameworks": "static",
            "extraPods": [
              {
                "name": "GoogleUtilities",
                "modular_headers": true
              },
              {
                "name": "RecaptchaInterop",
                "modular_headers": true
              }
            ]
          },
          "android": {
            "usesCleartextTraffic": true,
            "compileSdkVersion": 36,
            "targetSdkVersion": 35,
            "buildToolsVersion": "36.0.0"
          }
        }
      ],
      "expo-font",
      "expo-localization",
      "expo-audio",
      "@react-native-community/datetimepicker",
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "TAZQ needs access to the microphone to record your tasks.",
          "speechRecognitionPermission": "TAZQ needs access to speech recognition to convert your voice to text."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "TAZQ needs access to your calendar to sync your tasks."
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.995645524095-cd867f78b9768j1j8amr5oipee2cnr55"
        }
      ],
      "expo-apple-authentication",
      "@kingstinct/react-native-healthkit",
      "react-native-health-connect"
    ],
    "splash": {
      "image": "./assets/brand/splash_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E2A66"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tazqapp.tazq",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "TAZQ needs access to the microphone to record your tasks.",
        "NSSpeechRecognitionUsageDescription": "TAZQ needs access to speech recognition to convert your voice to text.",
        "NSPhotoLibraryUsageDescription": "TAZQ needs access to your photo library if you want to attach images to your tasks.",
        "NSCameraUsageDescription": "TAZQ needs access to your camera if you want to take photos for your tasks.",
        "NSHealthShareUsageDescription": "TAZQ reads your sleep data from Health to help you track your sleep habit.",
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/adaptive_foreground.png",
        "monochromeImage": "./assets/brand/adaptive_monochrome.png",
        "backgroundColor": "#0B0E1C"
      },
      "package": "com.tazqapp.tazq",
      "permissions": ["android.permission.health.READ_SLEEP"],
      "backgroundColor": "#000000",
      "softwareKeyboardLayoutMode": "resize",
      "navigationBar": {
        "backgroundColor": "#000000",
        "barStyle": "light-content"
      }
    },
    "web": {
      "favicon": "./assets/brand/icon.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "de37967e-e414-4881-ba6f-6e17f04c974e"
      }
    }
  }
}
