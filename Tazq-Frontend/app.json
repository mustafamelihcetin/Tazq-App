{
  "expo": {
    "name": "Tazq",
    "slug": "Tazq-Frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/tazq_icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "tazq-app",
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1",
            "newArchEnabled": false
          },
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-font",
      "expo-localization",
      "@react-native-community/datetimepicker"
    ],
    "splash": {
      "image": "./assets/images/tazq_splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tazqapp.tazq",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/tazq_icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.tazqapp.tazq",
      "backgroundColor": "#09090B",
      "navigationBar": {
        "backgroundColor": "#09090B",
        "barStyle": "light-content"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "de37967e-e414-4881-ba6f-6e17f04c974e"
      }
    }
  }
}
