<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Tazq_Frontend.ViewModels"
             xmlns:converters="clr-namespace:Tazq_Frontend.Converters"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:helpers="clr-namespace:Tazq_Frontend.Helpers"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Tazq_Frontend.Views.HomePage"
             x:Name="MainPageRoot"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             Background="{AppThemeBinding Light={StaticResource AppBackgroundBrushLight}, Dark={StaticResource AppBackgroundBrushDark}}">



    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
            <converters:NullOrEmptyToBoolConverter x:Key="NullOrEmptyToBoolConverter" />
            <converters:TagsArrayToStringConverter x:Key="TagsArrayToStringConverter" />
            <converters:PriorityToTurkishConverter x:Key="PriorityToTurkishConverter" />
            <converters:BoolToBorderColorConverter x:Key="BoolToBorderColorConverter" />
            <converters:PriorityToColorConverter x:Key="PriorityToColorConverter" />
            <converters:IsCompletedToIconConverter x:Key="IsCompletedToIconConverter" />
            <converters:BoolToStatusTextConverter x:Key="BoolToStatusTextConverter" />
            <converters:IsCompletedToColorConverter x:Key="IsCompletedToColorConverter" />
            <converters:IsCompletedToBackgroundColorConverter x:Key="IsCompletedToBackgroundColorConverter" />
            <converters:BoolToMaxLinesConverter x:Key="BoolToMaxLinesConverter" />
            <converters:BoolAndConverter x:Key="BoolAndConverter" />
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:BoolOrConverter x:Key="BoolOrConverter" />
            <converters:DueTodayHighlightMultiConverter x:Key="DueTodayHighlightMultiConverter" />

            <Style TargetType="RadioButton" x:Key="CustomRadioButtonStyle">
                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
                <Setter Property="FontFamily" Value="RobotoRegular" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Visual" Value="Default" />
                <Setter Property="ControlTemplate">
                    <Setter.Value>
                        <ControlTemplate>
                            <Grid ColumnSpacing="10">
                                <Ellipse WidthRequest="18"
                                         HeightRequest="18"
                                         Stroke="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                                         StrokeThickness="2"
                                         VerticalOptions="Center"
                                         HorizontalOptions="Start"
                                         Margin="0,0,4,0"
                                         Fill="{TemplateBinding IsChecked, Converter={StaticResource BoolToColorConverter}}" />
                                <Label Grid.Column="1"
                                       Text="{TemplateBinding Content}"
                                       VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}"
                                       FontFamily="RobotoRegular"
                                       FontSize="13" />
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <AbsoluteLayout>

        <Grid Padding="20" 
              RowSpacing="16" 
              AbsoluteLayout.LayoutBounds="0,0,1,1" 
              AbsoluteLayout.LayoutFlags="All">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Logo + icons -->
            <Grid x:Name="HeaderGrid" Grid.Row="0" ColumnSpacing="12" Margin="0,10,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

               <Image
                    Grid.Column="0"
                    x:Name="LogoImage"
                    Source="{Binding IsLightThemeEnabled, Converter={StaticResource HomePageLogoConverter}}"
                    HeightRequest="42"
                    HorizontalOptions="Start"
                    VerticalOptions="Center" />

                <HorizontalStackLayout Grid.Column="1" Spacing="12" VerticalOptions="Center">
                    <Frame Padding="0" CornerRadius="20" HasShadow="False" HeightRequest="40" WidthRequest="40" BackgroundColor="Transparent" BorderColor="Transparent">
                        <ImageButton Source="{Binding IsLightThemeEnabled, Converter={StaticResource FilterIconConverter}}"
                                     Command="{Binding ToggleFilterPanelCommand}"
                                     HeightRequest="26" WidthRequest="26" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Frame>

                    <Frame Padding="0" CornerRadius="20" HasShadow="False" HeightRequest="40" WidthRequest="40" BackgroundColor="Transparent" BorderColor="Transparent">
                        <ImageButton Source="{Binding IsLightThemeEnabled, Converter={StaticResource SettingsIconConverter}}"
                                     Command="{Binding ToggleSettingsPanelCommand}"
                                     HeightRequest="26" WidthRequest="26" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Frame>
                </HorizontalStackLayout>
            </Grid>

            <!-- Tasks -->
            <RefreshView x:Name="MainRefreshView"
                         Grid.Row="1"
                         Command="{Binding LoadTasksCommand}"
                         IsRefreshing="{Binding IsLoading}">
                
                <CollectionView x:Name="MainCollectionView"
                                ItemsSource="{Binding FilteredTasks}">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout Spacing="20" VerticalOptions="Center" HorizontalOptions="Center" Padding="40">
                             <Label Text="🚀" FontSize="48" HorizontalOptions="Center" />
                             <Label Text="Henüz görev eklenmedi."
                                    FontSize="18"
                                    FontAttributes="Bold"
                                    HorizontalOptions="Center"
                                    TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                             <Label Text="İlk görevini eklemek için alttaki butona dokun!"
                                    FontSize="14"
                                    HorizontalOptions="Center"
                                    HorizontalTextAlignment="Center"
                                    TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="16" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <SwipeView>
                                <SwipeView.RightItems>
                                    <SwipeItems Mode="Reveal">
                                        <SwipeItem BackgroundColor="#3B82F6"
                                                   Command="{Binding Path=BindingContext.EditTaskCommand, Source={x:Reference MainPageRoot}}"
                                                   CommandParameter="{Binding .}"
                                                   IconImageSource="edit_icon"
                                                   Text="Düzenle" />
                                        <SwipeItem BackgroundColor="#EF4444"
                                                   Command="{Binding Path=BindingContext.DeleteTaskCommand, Source={x:Reference MainPageRoot}}"
                                                   CommandParameter="{Binding .}"
                                                   IconImageSource="delete_icon"
                                                   Text="Sil" />
                                    </SwipeItems>
                                </SwipeView.RightItems>

                                <Frame x:Name="TaskItemFrame" 
                                       CornerRadius="16"
                                       Padding="0"
                                       HasShadow="True"
                                       BackgroundColor="Transparent">
                                    <Grid Background="{AppThemeBinding Light={StaticResource CardBackgroundBrushLight}, Dark={StaticResource CardBackgroundBrushDark}}"
                                          Padding="16" RowSpacing="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Title & Priority -->
                                        <Label Grid.Row="0" Grid.Column="0"
                                               Text="{Binding Title}"
                                               FontSize="17"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource Black}, Dark=White}" />

                                        <Frame Grid.Row="0" Grid.Column="1"
                                               Padding="8,4"
                                               BackgroundColor="{Binding PriorityEnum, Converter={StaticResource PriorityToColorConverter}}"
                                               CornerRadius="8"
                                               HasShadow="False">
                                            <Label Text="{Binding PriorityEnum, Converter={StaticResource PriorityToTurkishConverter}}"
                                                   FontSize="11"
                                                   TextColor="White"
                                                   FontAttributes="Bold"/>
                                        </Frame>

                                        <!-- Description -->
                                        <Label Grid.Row="1" Grid.ColumnSpan="2"
                                               Text="{Binding Description}"
                                               FontSize="14"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                                               IsVisible="{Binding Description, Converter={StaticResource NullOrEmptyToBoolConverter}}"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />

                                        <!-- Footer: DueDate & Checkbox -->
                                        <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnSpacing="12" VerticalOptions="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <HorizontalStackLayout Grid.Column="0" Spacing="6" VerticalOptions="Center" 
                                                                  IsVisible="{Binding HasDueDate}">
                                                <Label Text="📅" FontSize="12" VerticalOptions="Center" />
                                                <Label Text="{Binding DueDateTimeCombined, StringFormat='{0:dd MMM yyyy HH\\:mm}'}"
                                                       FontSize="12"
                                                       FontAttributes="Bold"
                                                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                                                       VerticalOptions="Center" />
                                            </HorizontalStackLayout>

                                            <Frame Grid.Column="1"
                                                   CornerRadius="20"
                                                   Padding="10,6"
                                                   HasShadow="False"
                                                   BackgroundColor="{Binding IsCompleted, Converter={StaticResource IsCompletedToBackgroundColorConverter}}"
                                                   VerticalOptions="Center">
                                                <HorizontalStackLayout Spacing="8">
                                                    <HorizontalStackLayout.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding Path=BindingContext.ToggleTaskCompletionCommand, Source={x:Reference MainPageRoot}}"
                                                                               CommandParameter="{Binding .}" />
                                                    </HorizontalStackLayout.GestureRecognizers>
                                                    <Image Source="{Binding IsCompleted, Converter={StaticResource IsCompletedToIconConverter}}"
                                                           WidthRequest="18" HeightRequest="18" />
                                                    <Label Text="{Binding IsCompleted, Converter={StaticResource BoolToStatusTextConverter}}"
                                                           FontSize="12"
                                                           FontAttributes="Bold"
                                                           TextColor="{Binding IsCompleted, Converter={StaticResource IsCompletedToColorConverter}}" />
                                                </HorizontalStackLayout>
                                            </Frame>
                                        </Grid>
                                    </Grid>
                                </Frame>
                            </SwipeView>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>
        </Grid>

        <!-- Floating Action Button (FAB) -->
        <Frame AbsoluteLayout.LayoutBounds="0.9, 0.9, 64, 64"
               AbsoluteLayout.LayoutFlags="PositionProportional"
               BackgroundColor="{StaticResource Primary}"
               CornerRadius="32"
               Padding="0"
               HasShadow="True">
            <ImageButton Source="plus_icon"
                         Command="{Binding GoToAddTaskPageCommand}"
                         Padding="16"
                         BackgroundColor="Transparent"
                         WidthRequest="64"
                         HeightRequest="64" />
        </Frame>

        <!-- Modal Panels (Filter & Settings) -->
        <Frame x:Name="FilterPanelFrame"
               BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
               Padding="20"
               CornerRadius="20"
               IsVisible="{Binding IsFilterPanelVisible}"
               AbsoluteLayout.LayoutBounds="0.5,0.5,0.85,-1"
               AbsoluteLayout.LayoutFlags="PositionProportional, WidthProportional"
               ZIndex="9999">
            <VerticalStackLayout Spacing="20">
                <Label Text="Filtrele" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" />
                
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Sadece Tamamlanmayanlar" VerticalOptions="Center" />
                    <Switch Grid.Column="1" IsToggled="{Binding IsShowOnlyIncomplete, Mode=TwoWay}" />
                </Grid>

                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Geçmiş Görevleri Göster" VerticalOptions="Center" />
                    <Switch Grid.Column="1" IsToggled="{Binding ShowPastTasks, Mode=TwoWay}" />
                </Grid>

                <Frame CornerRadius="12" Padding="12,0" BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}" HasShadow="False">
                    <Entry Placeholder="Etikete göre ara..." Text="{Binding FilterTag, Mode=TwoWay}" />
                </Frame>
                
                <Button Text="Uygula" Command="{Binding ToggleFilterPanelCommand}" />
            </VerticalStackLayout>
        </Frame>

        <Frame x:Name="SettingsPanelFrame"
               BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
               Padding="20"
               CornerRadius="20"
               IsVisible="{Binding IsSettingsPanelVisible}"
               AbsoluteLayout.LayoutBounds="0.5,0.5,0.85,-1"
               AbsoluteLayout.LayoutFlags="PositionProportional, WidthProportional"
               ZIndex="9999">
            <VerticalStackLayout Spacing="16">
                <Label Text="Ayarlar" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" />
                
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Açık Tema" VerticalOptions="Center" />
                    <Switch Grid.Column="1" IsToggled="{Binding IsLightThemeEnabled, Mode=TwoWay}" />
                </Grid>

                <Button Text="Bildirim Ayarları" Command="{Binding NotificationSettingsCommand}" StyleClass="SecondaryButton" />
                <Button Text="Hakkında" Command="{Binding AboutCommand}" StyleClass="SecondaryButton" />
                <Button Text="Çıkış Yap" Command="{Binding LogoutCommand}" BackgroundColor="#EF4444" />
                <Button Text="Kapat" Command="{Binding ToggleSettingsPanelCommand}" BackgroundColor="Transparent" TextColor="{StaticResource Primary}" />
            </VerticalStackLayout>
        </Frame>

        <!-- Overlay to close panels on click outside -->
        <BoxView AbsoluteLayout.LayoutBounds="0,0,1,1"
                 AbsoluteLayout.LayoutFlags="All"
                 BackgroundColor="#80000000"
                 ZIndex="9998">
            <BoxView.IsVisible>
                <MultiBinding Converter="{StaticResource BoolOrConverter}">
                    <Binding Path="IsFilterPanelVisible" />
                    <Binding Path="IsSettingsPanelVisible" />
                </MultiBinding>
            </BoxView.IsVisible>
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ToggleFilterPanelCommand}" />
                <TapGestureRecognizer Command="{Binding ToggleSettingsPanelCommand}" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <ActivityIndicator
            x:Name="LoadingIndicator"
            IsVisible="False"
            IsRunning="False"
            Color="#90CAF9"
            AbsoluteLayout.LayoutBounds="0.5,0.5,-1,-1"
            AbsoluteLayout.LayoutFlags="PositionProportional"
            WidthRequest="40"
            HeightRequest="40"
            ZIndex="9999"/>
    </AbsoluteLayout>
</ContentPage>
