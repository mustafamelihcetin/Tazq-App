<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Tazq_Frontend.ViewModels"
             x:Class="Tazq_Frontend.Views.EditTaskPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             Background="{AppThemeBinding Light={StaticResource AppBackgroundBrushLight}, Dark={StaticResource AppBackgroundBrushDark}}">


    <Grid Padding="20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <VerticalStackLayout Grid.Row="0" Spacing="5" Margin="0,10,0,10">
            <Label Text="Görevi Düzenle"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Primary}" />
            <Label Text="Planlarını güncelle ve devam et."
                   FontSize="14"
                   TextColor="{StaticResource Gray500}" />
        </VerticalStackLayout>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="16">

                <!-- Title -->
                <VerticalStackLayout Spacing="5">
                    <Label Text="Başlık" FontAttributes="Bold" FontSize="14" Margin="5,0" />
                    <Entry Placeholder="Görevin adı..."
                           Text="{Binding Title}"
                           MaxLength="80" />
                    <Label Text="{Binding TitleWarning}"
                           TextColor="#EF4444"
                           FontSize="12"
                           IsVisible="{Binding IsTitleLimitExceeded}"
                           Margin="5,0" />
                </VerticalStackLayout>

                <!-- Description -->
                <VerticalStackLayout Spacing="5">
                    <Label Text="Açıklama" FontAttributes="Bold" FontSize="14" Margin="5,0" />
                    <Editor Placeholder="Görev detayları..."
                            Text="{Binding Description}"
                            MaxLength="300" />
                    <Label Text="{Binding DescriptionWarning}"
                           TextColor="#EF4444"
                           FontSize="12"
                           IsVisible="{Binding IsDescriptionLimitExceeded}"
                           Margin="5,0" />
                </VerticalStackLayout>

                <!-- Date & Time -->
                <Frame Padding="12">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Tarih ve Saat" FontAttributes="Bold" FontSize="14" />
                        <DatePicker Date="{Binding DueDate}" Format="dd MMMM yyyy" />
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Saat belirle" VerticalOptions="Center" />
                            <HorizontalStackLayout Grid.Column="1" Spacing="10">
                                <CheckBox IsChecked="{Binding EnableTime}" Color="{StaticResource Primary}" />
                                <TimePicker Time="{Binding SelectedTime}" 
                                            Format="HH:mm" 
                                            IsVisible="{Binding EnableTime}" />
                            </HorizontalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- Priority & Tag -->
                <Grid ColumnSpacing="12" ColumnDefinitions="*,*">
                    <VerticalStackLayout Grid.Column="0" Spacing="5">
                        <Label Text="Öncelik" FontAttributes="Bold" FontSize="14" Margin="5,0" />
                        <Picker Title="Seçin"
                                ItemsSource="{Binding Priorities}"
                                SelectedItem="{Binding SelectedPriority}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Spacing="5">
                        <Label Text="Etiket" FontAttributes="Bold" FontSize="14" Margin="5,0" />
                        <Entry Placeholder="Etiket..."
                               Text="{Binding NewTag}"
                               Completed="OnTagCompleted"
                               MaxLength="30" />
                    </VerticalStackLayout>
                </Grid>

                <Label Text="{Binding TagsDisplay}"
                       TextColor="{StaticResource Primary}"
                       FontAttributes="Italic"
                       HorizontalOptions="Center" />

                <Grid ColumnSpacing="12" Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <Button Text="Vazgeç"
                            Clicked="OnBackClicked"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray800}}"
                            TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />

                    <Button Grid.Column="1"
                            Text="Değişiklikleri Kaydet"
                            Command="{Binding UpdateTaskCommand}" />
                </Grid>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>

