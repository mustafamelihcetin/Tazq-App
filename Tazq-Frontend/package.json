{
  "name": "tazq-frontend",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "fix": "npx expo install --fix && adb reverse tcp:8081 tcp:8081",
    "build:dev": "eas build --profile development --platform all",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@expo-google-fonts/cormorant-garamond": "^0.4.1",
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo-google-fonts/outfit": "^0.4.3",
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo-google-fonts/syne": "^0.4.2",
    "@expo/metro-runtime": "~55.0.10",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@types/i18n-js": "^3.0.3",
    "@types/lodash": "^4.17.24",
    "axios": "^1.6.8",
    "base64-js": "^1.5.1",
    "buffer": "^6.0.3",
    "expo": "~55.0.19",
    "expo-asset": "^55.0.16",
    "expo-blur": "~55.0.14",
    "expo-build-properties": "~55.0.13",
    "expo-camera": "^55.0.16",
    "expo-constants": "~55.0.15",
    "expo-dev-client": "~55.0.30",
    "expo-device": "^55.0.15",
    "expo-file-system": "^55.0.17",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.14",
    "expo-localization": "~55.0.13",
    "expo-navigation-bar": "~55.0.12",
    "expo-notifications": "~55.0.22",
    "expo-router": "~55.0.13",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "~55.0.16",
    "i18n-js": "^3.0.11",
    "lucide-react-native": "^0.473.0",
    "moti": "^0.30.0",
    "nativewind": "^4.0.36",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-css-interop": "^0.0.34",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.4",
    "zustand": "^4.5.2"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|moti|@motify/.*)"
    ],
    "setupFilesAfterFramework": [],
    "moduleNameMapper": {
      "\\.(png|jpg|jpeg|gif|svg)$": "<rootDir>/__mocks__/fileMock.js",
      "@react-native-async-storage/async-storage": "<rootDir>/__mocks__/asyncStorageMock.js"
    }
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@expo/ngrok": "^4.1.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.9.0",
    "@types/react": "~19.2.10",
    "babel-preset-expo": "~55.0.8",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.5",
    "postcss": "8.4.23",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
