{
  "name": "tazq-frontend",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client --clear",
    "dev": "expo start --dev-client --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "fix": "npx expo install --fix && adb reverse tcp:8081 tcp:8081",
    "build:dev": "eas build --profile development --platform all",
    "test": "jest",
    "test:watch": "jest --watch",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo-google-fonts/cormorant-garamond": "^0.4.1",
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo-google-fonts/outfit": "^0.4.3",
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo-google-fonts/syne": "^0.4.2",
    "@expo/config-plugins": "~56.0.0",
    "@expo/metro-runtime": "~56.0.15",
    "@kingstinct/react-native-healthkit": "^14.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-native-voice/voice": "^3.2.4",
    "@react-native/babel-plugin-codegen": "^0.85.3",
    "@react-native/babel-preset": "^0.85.3",
    "@react-native/codegen": "^0.85.3",
    "@sentry/react-native": "^8.15.1",
    "@shopify/react-native-skia": "2.6.2",
    "@types/i18n-js": "^3.0.3",
    "@types/lodash": "^4.17.24",
    "axios": "^1.18.1",
    "base64-js": "^1.5.1",
    "buffer": "^6.0.3",
    "expo": "^56.0.0",
    "expo-apple-authentication": "~56.0.4",
    "expo-asset": "~56.0.17",
    "expo-audio": "~56.0.12",
    "expo-blur": "~56.0.3",
    "expo-build-properties": "~56.0.19",
    "expo-calendar": "~56.0.8",
    "expo-camera": "~56.0.8",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.20",
    "expo-device": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-image-picker": "~56.0.19",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-localization": "~56.0.6",
    "expo-navigation-bar": "~56.0.3",
    "expo-notifications": "~56.0.18",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "i18n-js": "^3.0.11",
    "lucide-react-native": "^0.473.0",
    "moti": "^0.30.0",
    "nativewind": "^4.0.36",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "^0.85.3",
    "react-native-css-interop": "^0.0.34",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-health-connect": "^3.5.3",
    "react-native-nitro-modules": "^0.36.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.8.3",
    "zustand": "^4.5.2"
  },
  "jest": {
    "preset": "jest-expo",
    "testEnvironment": "node",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|@sentry/.*|native-base|react-native-svg|moti|@motify/.*|zustand|lucide-react-native)"
    ],
    "moduleNameMapper": {
      "\\.(png|jpg|jpeg|gif|svg)$": "<rootDir>/__mocks__/fileMock.js",
      "@react-native-async-storage/async-storage": "<rootDir>/__mocks__/asyncStorageMock.js"
    },
    "setupFiles": [
      "<rootDir>/__mocks__/setupTests.js"
    ],
    "collectCoverageFrom": [
      "app/**/*.{ts,tsx}",
      "features/**/*.{ts,tsx}",
      "shared/**/*.{ts,tsx}",
      "modules/**/*.{ts,tsx}",
      "!**/*.d.ts",
      "!**/__tests__/**",
      "!**/__mocks__/**",
      "!shared/constants/legal.ts",
      "!shared/constants/i18n.ts"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@expo/ngrok": "^4.1.3",
    "@react-native/jest-preset": "^0.86.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.10",
    "babel-preset-expo": "^56.0.15",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.5",
    "patch-package": "^8.0.1",
    "postcss": "8.4.23",
    "postinstall-postinstall": "^2.1.0",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
