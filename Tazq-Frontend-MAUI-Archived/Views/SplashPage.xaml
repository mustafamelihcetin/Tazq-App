<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:Tazq_Frontend.Views.Components"
             x:Class="Tazq_Frontend.Views.SplashPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             Background="{AppThemeBinding Light={StaticResource AppBackgroundBrushLight}, Dark={StaticResource AppBackgroundBrushDark}}">

    <Grid>
        <components:AnimatedBackground />

        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="24">
            <Image x:Name="Logo"
                   Source="{AppThemeBinding Light=tazq_white_logo_dark, Dark=tazq_white_logo}"
                   HeightRequest="60"
                   Aspect="AspectFit" />
            
            <ActivityIndicator x:Name="LoadingIndicator"
                               Color="{StaticResource Primary}"
                               IsRunning="True"
                               WidthRequest="40"
                               HeightRequest="40" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>