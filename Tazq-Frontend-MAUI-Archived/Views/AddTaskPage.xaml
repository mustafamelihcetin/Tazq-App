<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Tazq_Frontend.ViewModels"
             xmlns:components="clr-namespace:Tazq_Frontend.Views.Components"
             x:Class="Tazq_Frontend.Views.AddTaskPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             Background="{AppThemeBinding Light={StaticResource AppBackgroundBrushLight}, Dark={StaticResource AppBackgroundBrushDark}}">

    <Grid>
        <components:AnimatedBackground />

        <Grid RowDefinitions="Auto, *" Padding="24,40,24,24">
            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto, *" ColumnSpacing="12" Margin="0,0,0,24">
                <Border Grid.Column="0" WidthRequest="44" HeightRequest="44" 
                        Style="{StaticResource GlassBorder}" Padding="0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="←" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                    <Label Text="Yeni Görev" FontSize="24" FontAttributes="Bold" />
                </VerticalStackLayout>
            </Grid>

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Spacing="24" MaxWidthRequest="500" HorizontalOptions="Center" WidthRequest="340">
                    
                    <!-- Title & Description Group -->
                    <Border Style="{StaticResource GlassBorder}" Padding="0">
                        <VerticalStackLayout Padding="2">
                            <Entry Placeholder="Görevin adı..."
                                   Text="{Binding Title}"
                                   MaxLength="80"
                                   Margin="16,4" />
                            <BoxView Style="{StaticResource BoxView}" HeightRequest="1" Margin="16,0" Opacity="0.1" />
                            <Editor Placeholder="Açıklama (opsiyonel)..."
                                    Text="{Binding Description}"
                                    MaxLength="300"
                                    HeightRequest="120"
                                    Margin="16,4" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Settings Group -->
                    <Border Style="{StaticResource GlassBorder}">
                        <VerticalStackLayout Spacing="16">
                            <HorizontalStackLayout Spacing="12">
                                <Label Text="📅" FontSize="18" VerticalOptions="Center" />
                                <DatePicker Date="{Binding DueDate}" 
                                            Format="dd MMMM yyyy" 
                                            MinimumHeightRequest="44" />
                            </HorizontalStackLayout>

                            <BoxView Style="{StaticResource BoxView}" HeightRequest="1" Opacity="0.1" />

                            <Grid ColumnDefinitions="*, Auto">
                                <HorizontalStackLayout Spacing="12">
                                    <Label Text="⏰" FontSize="18" VerticalOptions="Center" />
                                    <Label Text="Saat belirle" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Grid.Column="1" Spacing="12">
                                    <Switch IsToggled="{Binding EnableTime}" Scale="0.8" />
                                    <TimePicker Time="{Binding SelectedTime}" 
                                                Format="HH:mm" 
                                                IsVisible="{Binding EnableTime}" />
                                </HorizontalStackLayout>
                            </Grid>

                            <BoxView Style="{StaticResource BoxView}" HeightRequest="1" Opacity="0.1" />

                            <Grid ColumnDefinitions="*, Auto">
                                <HorizontalStackLayout Spacing="12">
                                    <Label Text="🎯" FontSize="18" VerticalOptions="Center" />
                                    <Label Text="Öncelik" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <Picker Grid.Column="1"
                                        Title="Seçin"
                                        ItemsSource="{Binding Priorities}"
                                        SelectedItem="{Binding SelectedPriority}"
                                        HorizontalOptions="End" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Tags -->
                    <Border Style="{StaticResource GlassBorder}" Padding="0">
                        <Entry Placeholder="+ Etiket ekle"
                               Text="{Binding NewTag}"
                               Completed="OnTagCompleted"
                               Margin="16,4" />
                    </Border>

                    <Label Text="{Binding TagsDisplay}"
                           HorizontalOptions="Center"
                           FontSize="12"
                           Opacity="0.6" />

                    <Button Text="Görevi Kaydet"
                            Command="{Binding SaveTaskCommand}"
                            Margin="0,10,0,40" />
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>
