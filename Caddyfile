# ─────────────────────────────────────────────
# Malthen Ecosystem — Reverse Proxy Configuration
# All Malthen products share this Caddy instance
# ─────────────────────────────────────────────

# TAZQ — API
api.tazqapp.com {
    reverse_proxy tazq-backend:80
}

# TAZQ — Landing + legal pages (served from backend wwwroot)
tazqapp.com {
    reverse_proxy tazq-backend:80
}

# SEO: tek kanonik host — www her zaman apex'e 301 döner
www.tazqapp.com {
    redir https://tazqapp.com{uri} permanent
}

# Malthen Portfolio & Corporate
malthen.dev, www.malthen.dev {
    reverse_proxy malthen-app:8080
}

