# Database
DB_HOST=tazq-db
DB_PORT=5432
DB_NAME=tazqdb
DB_USER=tazqadmin
DB_PASSWORD=change_me_strong_password

# JWT
JWT_KEY=change_me_at_least_32_characters_long_secret_key
JWT_ISSUER=TazqApp
JWT_AUDIENCE=TazqUsers
JWT_EXPIRATION=60

# App
PORT=80
APP_SIGNATURE=tazq-expo-frontend
ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:5200

# SMTP
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your_email@gmail.com

# AI
GROQ_API_KEY=your_groq_api_key
